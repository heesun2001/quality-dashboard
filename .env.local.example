# ── 로컬 개발 ──────────────────────────────────────────────────
# 아래 변수를 설정하지 않으면 prisma/dev.db (SQLite 파일) 사용

# ── Vercel 프로덕션 (Turso LibSQL) ────────────────────────────
# https://turso.tech 에서 DB 생성 후 아래 값을 Vercel 환경변수에 설정
TURSO_DATABASE_URL=libsql://[db-name]-[org].turso.io
TURSO_AUTH_TOKEN=your_auth_token_here
